{
  "name": "thread-sleep-compat",
  "version": "0.1.1",
  "description": "thread-sleep the runs on multiple versions of node",
  "keywords": [
    "thread-sleep",
    "thread",
    "sleep"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:kmalakoff/thread-sleep-compat.git"
  },
  "license": "MIT",
  "main": "dist/cjs/index.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist",
    "assets",
    "out"
  ],
  "scripts": {
    "build": "tsds build",
    "format": "biome check --write --unsafe src/ test/",
    "test": "ts-swc mocha-compat test/spec/**/*.test.js",
    "test:engines": "nvu engines npm test",
    "version": "tsds version"
  },
  "dependencies": {
    "@types/mocha": "^10.0.10",
    "nan": "^2.16.0",
    "node-abi": "2.30.1",
    "semver": "^5.7.1",
    "thread-sleep": "^2.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "cmake-js": "^7.3.0",
    "cross-spawn-cb": "^1.1.3",
    "depcheck": "^1.4.7",
    "fast-extract": "^1.2.5",
    "fs-access-compat": "^1.0.3",
    "mocha-compat": "^3.6.2",
    "node-semvers": "^1.2.1",
    "prebuild": "^13.0.1",
    "queue-cb": "^1.4.4",
    "ts-dev-stack": "^1.4.3"
  },
  "packageManager": "npm@11.0.0+sha512.11dff29565d2297c74e7c594a9762581bde969f0aa5cbe6f5b3644bf008a16c065ece61094d9ffbb81125be38df8e1ba43eb8244b3d30c61eb797e9a2440e3ec",
  "engines": {
    "node": ">=0.8"
  },
  "tsds": {
    "source": "src/index.mjs",
    "targets": [
      "cjs"
    ]
  }
}
